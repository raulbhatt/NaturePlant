<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.rahul.natureplant.ui.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_navigationDecider"
            app:destination="@id/navigationDeciderFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/navigationDeciderFragment"
        android:name="com.rahul.natureplant.ui.NavigationDeciderFragment"
        android:label="Navigation Decider">
        <action
            android:id="@+id/action_navigationDecider_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/navigationDeciderFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_navigationDecider_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/navigationDeciderFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.rahul.natureplant.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.rahul.natureplant.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment" />
        <action
            android:id="@+id/action_homeFragment_to_categoryFragment"
            app:destination="@id/categoryFragment" />
        <action
            android:id="@+id/action_homeFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_homeFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
    </fragment>

    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.rahul.natureplant.ui.ProductDetailFragment"
        android:label="Product Detail"
        tools:layout="@layout/fragment_product_detail">
        <argument
            android:name="plant"
            app:argType="com.rahul.natureplant.model.Plant" />
        <action
            android:id="@+id/action_productDetailFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
        <action
            android:id="@+id/action_productDetailFragment_to_sellerProfileFragment"
            app:destination="@id/sellerProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/sellerProfileFragment"
        android:name="com.rahul.natureplant.ui.SellerProfileFragment"
        android:label="Seller Profile"
        tools:layout="@layout/fragment_seller_profile" />

    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.rahul.natureplant.ui.CategoryFragment"
        android:label="Categories"
        tools:layout="@layout/fragment_category" />

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.rahul.natureplant.ui.CartFragment"
        android:label="Cart"
        tools:layout="@layout/fragment_cart">
        <action
            android:id="@+id/action_cartFragment_to_checkoutFragment"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.rahul.natureplant.ui.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_profileFragment_to_orderHistoryFragment"
            app:destination="@id/orderHistoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.rahul.natureplant.ui.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.rahul.natureplant.ui.ChatFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_chat" />

    <fragment
        android:id="@+id/wishlistFragment"
        android:name="com.rahul.natureplant.ui.WishlistFragment"
        android:label="Wishlist"
        tools:layout="@layout/fragment_wishlist" />

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.rahul.natureplant.ui.CheckoutFragment"
        android:label="Checkout"
        tools:layout="@layout/fragment_checkout">
        <action
            android:id="@+id/action_checkoutFragment_to_shippingAddressFragment"
            app:destination="@id/shippingAddressFragment" />
        <action
            android:id="@+id/action_checkoutFragment_to_chooseShippingFragment"
            app:destination="@id/chooseShippingFragment" />
        <action
            android:id="@+id/action_checkoutFragment_to_paymentSuccessFragment"
            app:destination="@id/paymentSuccessFragment" />
    </fragment>

    <fragment
        android:id="@+id/shippingAddressFragment"
        android:name="com.rahul.natureplant.ui.ShippingAddressFragment"
        android:label="Shipping Address"
        tools:layout="@layout/fragment_shipping_address">
        <action
            android:id="@+id/action_shippingAddressFragment_to_addAddressFragment"
            app:destination="@id/addAddressFragment" />
    </fragment>

    <fragment
        android:id="@+id/addAddressFragment"
        android:name="com.rahul.natureplant.ui.AddAddressFragment"
        android:label="Add Address"
        tools:layout="@layout/fragment_add_address" />

    <fragment
        android:id="@+id/chooseShippingFragment"
        android:name="com.rahul.natureplant.ui.ChooseShippingFragment"
        android:label="Choose Shipping"
        tools:layout="@layout/fragment_choose_shipping" />

    <fragment
        android:id="@+id/paymentSuccessFragment"
        android:name="com.rahul.natureplant.ui.PaymentSuccessFragment"
        android:label="Payment Success"
        tools:layout="@layout/dialog_payment_success">
        <action
            android:id="@+id/action_paymentSuccessFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_paymentSuccessFragment_to_eReceiptFragment"
            app:destination="@id/eReceiptFragment" />
        <action
            android:id="@+id/action_paymentSuccessFragment_to_orderSummaryFragment"
            app:destination="@id/orderSummaryFragment" />
    </fragment>

    <fragment
        android:id="@+id/eReceiptFragment"
        android:name="com.rahul.natureplant.ui.EReceiptFragment"
        android:label="E-Receipt"
        tools:layout="@layout/fragment_e_receipt" />

    <fragment
        android:id="@+id/orderSummaryFragment"
        android:name="com.rahul.natureplant.ui.OrderSummaryFragment"
        android:label="Order Summary"
        tools:layout="@layout/fragment_order_summary" />

    <fragment
        android:id="@+id/orderHistoryFragment"
        android:name="com.rahul.natureplant.ui.OrderHistoryFragment"
        android:label="Order History"
        tools:layout="@layout/fragment_order_history">
        <action
            android:id="@+id/action_orderHistoryFragment_to_trackOrderFragment"
            app:destination="@id/trackOrderFragment" />
        <action
            android:id="@+id/action_orderHistoryFragment_to_leaveReviewFragment"
            app:destination="@id/leaveReviewFragment" />
    </fragment>

    <fragment
        android:id="@+id/leaveReviewFragment"
        android:name="com.rahul.natureplant.ui.LeaveReviewFragment"
        android:label="Leave Review"
        tools:layout="@layout/fragment_leave_review">
        <argument
            android:name="plant"
            app:argType="com.rahul.natureplant.model.Plant" />
    </fragment>

    <fragment
        android:id="@+id/trackOrderFragment"
        android:name="com.rahul.natureplant.ui.TrackOrderFragment"
        android:label="Track Order"
        tools:layout="@layout/fragment_track_order">
        <argument
            android:name="plant"
            app:argType="com.rahul.natureplant.model.Plant" />
    </fragment>

</navigation>
